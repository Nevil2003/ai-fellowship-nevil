# ── Supabase (optional — leave blank to keep localStorage-only mode) ──
# Create a project at https://supabase.com and paste the values from
# Project Settings → API.  Both values are public/anon — safe to ship
# to the browser.  Row-level security (see supabase/schema.sql) keeps
# each user's data isolated.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (server-only — NEVER expose to the browser).
# Required for the WhatsApp bot to persist per-phone conversations.
# Get it from Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# ── WhatsApp Business Cloud API (Meta) ─────────────────────────
# Create an app at https://developers.facebook.com/apps → add WhatsApp product.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Any random string you invent — paste the SAME value into Meta when
# you configure the webhook. Used only during the first handshake.
WHATSAPP_VERIFY_TOKEN=propstical-verify-change-me

# ── AI brain (server-side, for the WhatsApp bot) ───────────────
# Can be different from the web canvas key (which lives in localStorage).
# Recommended: OpenRouter + Claude Sonnet 4.5
AI_PROVIDER=openrouter
AI_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4-5

# Optional: OpenAI key used ONLY for Whisper voice-note transcription.
# Leave blank to disable voice-note support.
OPENAI_API_KEY=

# ── Telegram bot (easier alternative to WhatsApp — no verification) ──
# Get a token instantly from @BotFather on Telegram (/newbot).
TELEGRAM_BOT_TOKEN=
# Optional: a random string you invent. If set, Telegram echoes it on
# every webhook request so you can reject spoofed traffic.
TELEGRAM_WEBHOOK_SECRET=
